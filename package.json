{
  "name": "sync-gui",
  "version": "1.0.0",
  "main": "electron/main.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/hamidrg20001379/sync-gui-public.git"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "electron": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "electron:dev": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "dist": "npm run build && node scripts/package.js",
