{
  "projects": [
    {
      "id": "demo-shop",
      "label": "Demo Shop",
      "root": ".\\demo-workspace\\demo-shop",
      "remotes": [
        {
          "id": "production",
          "remoteId": "mock-production",
          "label": "Production",
          "categories": [
            {
              "id": "backend",
              "label": "Backend",
              "mappings": [
                {
                  "id": "api",
                  "label": "API folder",
                  "type": "dir",
                  "local": "backend/api",
                  "remote": "/var/www/demo-shop/backend/api"
                }
              ],
              "categories": []
            },
            {
              "id": "frontend",
              "label": "Frontend",
              "mappings": [
                {
                  "id": "assets",
                  "label": "Assets",
                  "type": "dir",
                  "local": "frontend/assets",
                  "remote": "/var/www/demo-shop/public/assets"
                },
                {
                  "id": "index",
                  "label": "Home page",
                  "type": "file",
                  "local": "frontend/index.html",
                  "remote": "/var/www/demo-shop/public/index.html"
                }
              ],
              "categories": []
            }
          ]
        },
        {
          "id": "staging",
          "remoteId": "mock-staging",
          "label": "Staging",
          "categories": [
            {
              "id": "preview",
              "label": "Preview bundle",
              "mappings": [
                {
                  "id": "preview-build",
                  "label": "Preview build",
                  "type": "dir",
                  "local": "frontend/dist",
                  "remote": "/srv/preview/demo-shop"
                }
              ],
              "categories": []
            }
          ]
        }
      ]
    }
  ],
  "remotes": [
    {
      "id": "mock-production",
      "label": "Mock Production",
      "kind": "ssh",
      "hostEnv": "SERVER_HOST",
      "portEnv": "SERVER_PORT",
      "usernameEnv": "SERVER_USERNAME",
      "passwordEnv": "SERVER_PASSWORD"
    },
    {
      "id": "mock-staging",
      "label": "Mock Staging Share",
      "kind": "local",
      "root": ".\\demo-workspace\\remote-staging"
    }
  ],
  "ui": {
    "projectId": "demo-shop",
    "remoteId": "production",
    "categoryPath": []
  }
}
