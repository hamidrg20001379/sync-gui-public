generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Template {
  id                  String    @id
  name                String
  relativePath        String    @default("") @map("relative_path")
  relativeRemotePath  String    @default("") @map("relative_remote_path")
  variableKeys        String    @default("[]") @map("variable_keys")
  hidden              Int       @default(0)

  categories          Category[]
  mappings            Mapping[]

  @@map("templates")
}

model Project {
  id       String  @id
  name     String
  rootPath String  @map("root_path")

  projectRemotes ProjectRemote[]
  streams        Stream[]
  syncTargets    SyncTarget[]

  @@map("projects")
}

model Remote {
  id         String  @id
  name       String
  kind       String
  rootPath   String? @map("root_path")
  configJson String  @default("{}") @map("config_json")

  projectRemotes ProjectRemote[]

  @@map("remotes")
}

model ProjectRemote {
  id        String  @id
  projectId String  @map("project_id")
  remoteId  String  @map("remote_id")
  name      String

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  remote     Remote      @relation(fields: [remoteId], references: [id], onDelete: Restrict)
  categories Category[]

  @@unique([projectId, id])
  @@map("project_remotes")
}

model Stream {
  id        String @id
  projectId String @map("project_id")
  name      String

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  categories Category[]

  @@map("streams")
}

model SyncTarget {
  id        String @id
  projectId String @map("project_id")
  targetKey String @map("target_key")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("sync_targets")
}

model Category {
  id                String   @id
  projectRemoteId   String?  @map("project_remote_id")
  streamId          String?  @map("stream_id")
  templateId        String   @map("template_id")
  parentId          String?  @map("parent_id")
  variables         String   @default("{}")
  hidden            Int      @default(0)
  sortOrder         Int      @default(0) @map("sort_order")

  projectRemote     ProjectRemote? @relation(fields: [projectRemoteId], references: [id], onDelete: Cascade)
  stream            Stream?        @relation(fields: [streamId], references: [id], onDelete: Cascade)
  template          Template      @relation(fields: [templateId], references: [id], onDelete: Restrict)
  parent            Category?     @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children          Category[]    @relation("CategoryTree")
  mappings          Mapping[]

  @@map("categories")
}

model Mapping {
  id              String   @id
  categoryId      String   @map("category_id")
  templateId      String   @map("template_id")
  type            String
  variables       String   @default("{}")
  hidden          Int      @default(0)
  sortOrder       Int      @default(0) @map("sort_order")

  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  template        Template @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@map("mappings")
}
